# Copy to .env and fill in real values. .env is gitignored; this file is the committed template.

# Postgres connection for application data (system of record)
DATABASE_URL=postgresql://localhost/civic

# Postgres connection for DBOS workflow state — separate database, same instance
DBOS_SYSTEM_DATABASE_URL=postgresql://localhost/civic_dbos

# api.open.fec.gov key (7,200 calls/hr) — incremental FEC updates and lookups
FEC_API_KEY=

# api.congress.gov key — bills, roll-call votes, members
CONGRESS_GOV_API_KEY=

# YouTube Data API key — town hall / interview discovery and captions
YOUTUBE_API_KEY=

# OpenAI-compatible endpoint of the vLLM server on the Lambda GPU box (empty locally)
VLLM_BASE_URL=

# Model name served by vLLM (e.g. deepseek-v3); empty locally
LOCAL_MODEL=

# Whether GPU-dependent stages (transcription, local LLM) may run on this machine
GPU_AVAILABLE=false
